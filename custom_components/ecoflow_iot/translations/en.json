          "secret_key": "Secret Key"
        }
      }
    },
    "error": {
      "invalid_auth": "Invalid Access Key or Secret Key.",
      "cannot_connect": "Failed to connect to the EcoFlow API.",
      "unknown": "Unexpected error."
    },
    "abort": {
      "already_configured": "These credentials are already configured.",
      "reauth_successful": "Re-authentication was successful."
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "EcoFlow IoT options",
        "data": {
          "enable_mqtt": "Use MQTT for live data",
          "poll_interval": "HTTP poll interval (seconds)",
          "mqtt_stale_seconds": "MQTT staleness threshold (seconds)",
          "invert_grid_sign": "Invert Stream grid power sign",
          "reset_grid_energy": "Reset grid import/export energy totals & history"
        },
        "data_description": {
          "poll_interval": "How often to poll the HTTP API (fallback when MQTT is unavailable, and the cadence for refreshing HTTP-only values).",
          "mqtt_stale_seconds": "If no MQTT message arrives within this window, the integration polls HTTP.",
          "invert_grid_sign": "Some Stream units report grid power with the sign inverted — they show power fed into the grid as positive instead of negative, the opposite of Home Assistant's convention. This depends on the model and firmware, so it can't be detected automatically. Leave this on (the default) and the sign is corrected: Grid power reads negative while you export, and the Grid import / export energy sensors count in the right direction. Turn it off only if your unit already matches Home Assistant — i.e. exporting to the grid already shows Grid power as negative (import positive, export negative). If you change this setting, also tick \"Reset grid import/export energy totals\" below — the existing totals were built up in the wrong direction and won't correct themselves.",
          "reset_grid_energy": "One-shot action: tick this and save to fully reset the Grid import energy and Grid export energy sensors. It zeroes the live counters and deletes their recorded history and Energy Dashboard statistics, so the old wrong-direction data is gone and they start fresh from zero. Recommended after changing the sign setting above. Leave it off for normal use."
        }
      }
    }
  },
